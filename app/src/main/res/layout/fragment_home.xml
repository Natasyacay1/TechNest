<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?android:attr/windowBackground"> <View
    android:id="@+id/bgGlow"
    android:layout_width="250dp"
    android:layout_height="250dp"
    android:background="@android:drawable/screen_background_dark_transparent"
    android:backgroundTint="#00E5FF"
    android:alpha="0.02"
    app:layout_constraintTop_toTopOf="parent"
    app:layout_constraintLeft_toLeftOf="parent"
    android:layout_marginTop="-50dp"
    android:layout_marginStart="-50dp"/>

    <RelativeLayout
        android:id="@+id/headerBar"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:paddingHorizontal="24dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerVertical="true"
            android:text="TECHNEST"
            android:textColor="?android:attr/textColorPrimary" android:textSize="18sp"
            android:fontFamily="sans-serif-black"
            android:textStyle="bold"
            android:letterSpacing="0.1"
            tools:ignore="HardcodedText"/>

        <ImageButton
            android:id="@+id/btn_refresh"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:background="@android:color/transparent"
            android:src="@android:drawable/stat_notify_sync"
            app:tint="?android:attr/textColorPrimary" tools:ignore="ContentDescription,TouchTargetSizeCheck"/>
    </RelativeLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        android:scrollbars="none"
        app:layout_constraintTop_toBottomOf="@id/headerBar"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="80dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginHorizontal="24dp"
                android:layout_marginTop="8dp"
                android:background="@android:drawable/screen_background_dark_transparent"
                android:backgroundTint="?android:attr/colorBackground" android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingHorizontal="16dp">

                <ImageView
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:src="@android:drawable/ic_menu_search"
                    app:tint="?android:attr/textColorSecondary" tools:ignore="ContentDescription"/>

                <EditText
                    android:id="@+id/search_bar"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_marginStart="12dp"
                    android:background="@android:color/transparent"
                    android:hint="Search elite hardware..."
                    android:textColorHint="?android:attr/textColorSecondary" android:textColor="?android:attr/textColorPrimary" android:textSize="14sp"
                    android:inputType="text"
                    tools:ignore="Autofill,TouchTargetSizeCheck,HardcodedText"/>
            </LinearLayout>

            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:scrollbars="none"
                android:paddingStart="24dp"
                android:paddingEnd="4dp"
                tools:ignore="RtlSymmetry">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/btnSemuaProduk"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@android:drawable/screen_background_dark_transparent"
                        android:backgroundTint="#00E5FF"
                        android:paddingHorizontal="16dp"
                        android:paddingVertical="8dp"
                        android:text="Semua"
                        android:textColor="#0B0D0F"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:layout_marginEnd="8dp"
                        tools:ignore="HardcodedText"/>

                    <TextView
                        android:id="@+id/btnSmartphone"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@android:drawable/screen_background_dark_transparent"
                        android:backgroundTint="?android:attr/colorBackground" android:paddingHorizontal="16dp"
                        android:paddingVertical="8dp"
                        android:text="Smartphone"
                        android:textColor="?android:attr/textColorSecondary" android:textSize="12sp"
                        android:layout_marginEnd="8dp"
                        tools:ignore="HardcodedText"/>

                    <TextView
                        android:id="@+id/btnLaptop"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@android:drawable/screen_background_dark_transparent"
                        android:backgroundTint="?android:attr/colorBackground" android:paddingHorizontal="16dp"
                        android:paddingVertical="8dp"
                        android:text="Laptop"
                        android:textColor="?android:attr/textColorSecondary" android:textSize="12sp"
                        android:layout_marginEnd="8dp"
                        tools:ignore="HardcodedText"/>

                    <TextView
                        android:id="@+id/btnTablet"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@android:drawable/screen_background_dark_transparent"
                        android:backgroundTint="?android:attr/colorBackground" android:paddingHorizontal="16dp"
                        android:paddingVertical="8dp"
                        android:text="Tablet"
                        android:textColor="?android:attr/textColorSecondary" android:textSize="12sp"
                        android:layout_marginEnd="24dp"
                        tools:ignore="HardcodedText"/>

                </LinearLayout>
            </HorizontalScrollView>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="180dp"
                android:layout_marginHorizontal="24dp"
                android:layout_marginTop="24dp"
                app:cardBackgroundColor="?android:attr/colorBackground" app:cardCornerRadius="16dp"
                app:cardElevation="0dp">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:padding="20dp">

                    <TextView
                        android:id="@+id/promoLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="NEW ARRIVAL"
                        android:textColor="#00E5FF"
                        android:textSize="10sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.1"
                        tools:ignore="HardcodedText"/>

                    <TextView
                        android:id="@+id/promoTitle"
                        android:layout_width="180dp"
                        android:layout_height="wrap_content"
                        android:layout_below="@id/promoLabel"
                        android:layout_marginTop="4dp"
                        android:text="NEXUS PRIME X1"
                        android:textColor="?android:attr/textColorPrimary" android:textSize="22sp"
                        android:fontFamily="sans-serif-black"
                        android:textStyle="bold"
                        tools:ignore="HardcodedText"/>

                    <TextView
                        android:layout_width="160dp"
                        android:layout_height="wrap_content"
                        android:layout_below="@id/promoTitle"
                        android:layout_marginTop="6dp"
                        android:text="Experience the future of mobile intelligence."
                        android:textColor="?android:attr/textColorSecondary" android:textSize="11sp"
                        tools:ignore="HardcodedText"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentBottom="true"
                        android:background="@android:drawable/screen_background_dark_transparent"
                        android:backgroundTint="#00E5FF"
                        android:paddingHorizontal="14dp"
                        android:paddingVertical="6dp"
                        android:text="EXPLORE SPECS"
                        android:textColor="#0B0D0F"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        tools:ignore="HardcodedText"/>

                    <ImageView
                        android:layout_width="120dp"
                        android:layout_height="120dp"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:src="@android:drawable/stat_sys_phone_call"
                        android:alpha="0.15"
                        app:tint="#00E5FF"
                        tools:ignore="ContentDescription"/>
                </RelativeLayout>
            </androidx.cardview.widget.CardView>

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="28dp"
                android:paddingHorizontal="24dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Curated Essentials"
                    android:textColor="?android:attr/textColorPrimary" android:textSize="16sp"
                    android:fontFamily="sans-serif-medium"
                    android:textStyle="bold"
                    tools:ignore="HardcodedText"/>

                <TextView
                    android:id="@+id/tv_view_all"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:text="View All"
                    android:textColor="#00E5FF"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    tools:ignore="HardcodedText"/>
            </RelativeLayout>

            <ProgressBar
                android:id="@+id/progress_bar"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:layout_gravity="center"
                android:layout_marginTop="30dp"
                android:indeterminateTint="#00E5FF"
                android:visibility="gone"/>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_products"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:layout_marginHorizontal="24dp"
                android:nestedScrollingEnabled="false"
                tools:listitem="@layout/item_product"/>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>