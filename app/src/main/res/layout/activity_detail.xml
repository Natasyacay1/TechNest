<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#0F1113">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Gambar + Tombol Back -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="280dp">

                <ImageView
                    android:id="@+id/img_detail"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerCrop"
                    android:src="@drawable/ic_technest_logo"/>

                <ImageButton
                    android:id="@+id/btn_detail_back"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_margin="16dp"
                    android:background="@drawable/bg_btn_back"
                    android:src="@drawable/ic_back"
                    android:padding="8dp"
                    app:tint="#FFFFFF"/>
            </FrameLayout>

            <!-- Info Produk -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <!-- Brand -->
                <TextView
                    android:id="@+id/tv_detail_brand"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="APPLE"
                    android:textColor="#00BCD4"
                    android:textSize="11sp"
                    android:letterSpacing="0.08"/>

                <!-- Nama Produk -->
                <TextView
                    android:id="@+id/tv_detail_title"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="iPhone 14 Pro Max"
                    android:textColor="#FFFFFF"
                    android:textSize="20sp"
                    android:textStyle="bold"/>

                <!-- Rating -->
                <TextView
                    android:id="@+id/tv_detail_rating"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="⭐ 4.8"
                    android:textColor="#888888"
                    android:textSize="13sp"/>

                <!-- Harga -->
                <TextView
                    android:id="@+id/tv_detail_price"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="Rp 15.000.000"
                    android:textColor="#00BCD4"
                    android:textSize="22sp"
                    android:textStyle="bold"/>

                <!-- Garis pemisah -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="0.5dp"
                    android:layout_marginTop="16dp"
                    android:layout_marginBottom="16dp"
                    android:background="#2A2D31"/>

                <!-- Deskripsi -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="DESKRIPSI"
                    android:textColor="#00BCD4"
                    android:textSize="11sp"
                    android:letterSpacing="0.08"/>

                <TextView
                    android:id="@+id/tv_detail_desc"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="Deskripsi produk..."
                    android:textColor="#AAAAAA"
                    android:textSize="14sp"
                    android:lineSpacingExtra="4dp"/>

            </LinearLayout>
        </LinearLayout>
    </ScrollView>

    <!-- Tombol Bawah -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:background="#0F1113">

        <Button
            android:id="@+id/btn_detail_add_cart"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:layout_marginEnd="8dp"
            android:text="+ Keranjang"
            android:textColor="#00BCD4"
            android:backgroundTint="#1A1D21"
            app:strokeColor="#00BCD4"
            app:strokeWidth="1dp"
            app:cornerRadius="10dp"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"/>

        <Button
            android:id="@+id/btn_detail_buy_now"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:text="Beli Sekarang"
            android:textColor="#0F1113"
            android:textStyle="bold"
            android:backgroundTint="#00BCD4"
            app:cornerRadius="10dp"/>

    </LinearLayout>

</LinearLayout>